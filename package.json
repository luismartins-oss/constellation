{
  "name": "@luismartinsoss/constellation",
  "version": "0.2.0",
  "description": "Contexto de projeto para agentes de IA — estrelas versionadas, índice barato, grafo estelar navegável",
  "type": "module",
  "bin": { "constellation": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "license": "MIT",
  "author": "luismartinsoss",
  "keywords": [
    "ai",
    "agents",
    "context",
    "knowledge-graph",
    "memory",
    "cli",
    "llm",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luismartins-oss/constellation.git"
  },
  "homepage": "https://github.com/luismartins-oss/constellation#readme",
  "bugs": {
    "url": "https://github.com/luismartins-oss/constellation/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
